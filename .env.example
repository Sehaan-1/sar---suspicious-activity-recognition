# Required: use long, random values outside local development.
JWT_SECRET="replace-with-a-long-random-jwt-secret"
INGEST_API_KEY="replace-with-a-long-random-ingest-key"

# Optional: used once to seed the first admin account when the users table is empty.
ADMIN_EMAIL="replace-with-admin-email@example.com"
ADMIN_PASSWORD="replace-with-a-strong-admin-password"

PORT=3000
CLEANUP_MAX_AGE_DAYS=30

# Optional Gemini integration.
GEMINI_API_KEY=""
APP_URL="http://localhost:3000"
